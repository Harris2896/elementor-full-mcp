{
  "name": "leobot/elementor-mcp-bridge",
  "description": "WordPress bridge plugin for Elementor MCP",
  "type": "wordpress-plugin",
  "license": "MIT",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "brain/monkey": "^2.6",
    "10up/wp_mock": "^1.0"
  },
  "autoload": {
    "psr-4": {"ElementorMCP\\": "includes/"}
  },
  "autoload-dev": {
    "psr-4": {"ElementorMCP\\Tests\\": "tests/"}
  },
  "scripts": {
    "test": "phpunit"
  }
}
